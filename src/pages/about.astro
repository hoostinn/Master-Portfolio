---
import BaseLayout from '../layouts/BaseLayout.astro';
import ProfileCard from '../components/ProfileCard.astro';
import AboutMini from '../components/AboutMini.astro';

const milestones = [
  {
    date: 'Jul 2025',
    title: 'Engineering & Implementations Intern',
    org: 'Facilitron',
  },
  {
    date: 'Mar 2026',
    title: 'AWS Certified Cloud Practitioner',
    org: 'Amazon Web Services',
  },
  {
    date: 'Apr 2026',
    title: 'OTTER shipped',
    org: 'Senior Capstone — CSUMB',
  },
  {
    date: 'May 2026',
    title: 'B.S. Computer Science',
    org: 'California State University, Monterey Bay',
  },
] as const;
---

<BaseLayout
  title="About — Justin Park"
  description="Justin Park is a software engineer who builds developer tools and AI-assisted products. CS graduate, AWS certified, open-source contributor."
>
  <div class="mx-auto max-w-5xl px-6 py-20 space-y-16">

    <!-- Profile card -->
    <ProfileCard />

    <!-- Divider -->
    <hr class="border-border dark:border-dark-border" />

    <!-- What I Do + Tech Stack -->
    <AboutMini />

    <!-- Divider -->
    <hr class="border-border dark:border-dark-border" />

    <!-- Story -->
    <section aria-labelledby="story-heading" class="fade-in">
      <h2
        id="story-heading"
        class="text-xs font-semibold uppercase tracking-widest text-text-faint dark:text-dark-text-faint mb-8"
      >
        Background
      </h2>

      <div class="prose max-w-prose space-y-5">
        <p class="text-text dark:text-dark-text leading-relaxed">
          I build developer tools and AI-assisted software — the kind of things that make
          technical workflows faster, clearer, and less painful to reason about. I'm drawn to
          the gap between what a tool could do and what it actually does for the person using
          it. Closing that gap is the work I find most interesting.
        </p>

        <p class="text-text dark:text-dark-text leading-relaxed">
          At Facilitron, I shipped an OCR pipeline that reduced manual data processing time by
          50%, cutting implementation turnaround from two to three days down to one. The problem
          was real and repetitive: thirty-plus district database migrations, each requiring hours
          of manual form parsing. I identified the bottleneck, proposed the automation, built it
          in Python, and applied it directly to production workflows — saving ten-plus hours per
          project. That's the kind of work I want to keep doing: see the inefficiency, build the
          fix, measure the result.
        </p>

        <p class="text-text dark:text-dark-text leading-relaxed">
          Before that, I led frontend development on OTTER, an open-source, local-first desktop
          app that lets audio creators edit their recordings by editing text — instead of
          scrubbing waveforms. Built with React, Electron, TypeScript, and Python, shipped with
          an eight-person engineering team as our senior capstone at CSUMB. OTTER is where I
          learned what it means to manage scope under pressure: we intentionally cut audio
          re-stitching from the proof of concept so we could ship something real on deadline.
          The right call. I also set up our CI/CD pipeline with GitHub Actions, wrote the Jest
          test suite, and coordinated sprint timelines across the team.
        </p>

        <p class="text-text dark:text-dark-text leading-relaxed">
          Outside of shipped projects, I'm AWS Certified Cloud Practitioner and have hands-on
          experience integrating large language models into production workflows using the Claude
          API and Anthropic SDK — including tool use, function calling, and agentic pipelines.
          I'm interested in the intersection of AI capability and practical engineering: not AI
          for its own sake, but AI as a lever that makes real software measurably better.
        </p>

        <p class="text-text-muted dark:text-dark-text-muted leading-relaxed">
          I graduated from CSUMB's Software Engineering program in May 2026. Long term, I'm
          working toward engineering leadership — roles where I can stay close to the technical
          work while helping teams ship at their best.
        </p>
      </div>
    </section>

    <!-- Divider -->
    <hr class="border-border dark:border-dark-border" />

    <!-- Milestones -->
    <section aria-labelledby="milestones-heading" class="fade-in">
      <h2
        id="milestones-heading"
        class="text-xs font-semibold uppercase tracking-widest text-text-faint dark:text-dark-text-faint mb-10"
      >
        Timeline
      </h2>

      <!-- Desktop: horizontal -->
      <ol
        class="hidden sm:grid sm:grid-cols-4 relative list-none p-0 m-0"
        role="list"
        aria-label="Career milestones"
      >
        <!-- Connecting line -->
        <div
          class="absolute top-[18px] left-[12.5%] right-[12.5%] h-px bg-border dark:bg-dark-border"
          aria-hidden="true"
        ></div>

        {milestones.map((m, i) => (
          <li class="flex flex-col items-center text-center px-3">
            <!-- Dot -->
            <div
              class:list={[
                'w-3 h-3 rounded-full border-2 relative z-10 mb-4',
                i === milestones.length - 1
                  ? 'bg-accent dark:bg-dark-accent border-accent dark:border-dark-accent'
                  : 'bg-surface dark:bg-dark-surface border-primary dark:border-dark-primary',
              ]}
              aria-hidden="true"
            ></div>
            <time
              class="text-xs font-semibold text-primary dark:text-dark-primary mb-1 block"
            >
              {m.date}
            </time>
            <p class="text-sm font-semibold text-text dark:text-dark-text leading-snug mb-0.5">
              {m.title}
            </p>
            <p class="text-xs text-text-faint dark:text-dark-text-faint leading-snug">
              {m.org}
            </p>
          </li>
        ))}
      </ol>

      <!-- Mobile: vertical -->
      <ol
        class="sm:hidden flex flex-col gap-6 list-none p-0 m-0 relative"
        role="list"
        aria-label="Career milestones"
      >
        <!-- Connecting line -->
        <div
          class="absolute top-3 bottom-3 left-[5px] w-px bg-border dark:bg-dark-border"
          aria-hidden="true"
        ></div>

        {milestones.map((m, i) => (
          <li class="flex gap-5 items-start pl-1">
            <div
              class:list={[
                'w-3 h-3 rounded-full border-2 flex-shrink-0 mt-1 relative z-10',
                i === milestones.length - 1
                  ? 'bg-accent dark:bg-dark-accent border-accent dark:border-dark-accent'
                  : 'bg-surface dark:bg-dark-surface border-primary dark:border-dark-primary',
              ]}
              aria-hidden="true"
            ></div>
            <div>
              <time class="text-xs font-semibold text-primary dark:text-dark-primary block mb-0.5">
                {m.date}
              </time>
              <p class="text-sm font-semibold text-text dark:text-dark-text leading-snug">{m.title}</p>
              <p class="text-xs text-text-faint dark:text-dark-text-faint mt-0.5">{m.org}</p>
            </div>
          </li>
        ))}
      </ol>
    </section>

    <!-- Bottom resume CTA -->
    <div class="flex justify-center pb-4 fade-in">
      <a
        href="/assets/resume.pdf"
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-2 px-6 py-3 rounded-lg bg-accent hover:bg-accent-hover dark:bg-dark-accent dark:hover:bg-dark-accent-hover text-text font-semibold transition-colors duration-200 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-accent"
      >
        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
            d="M12 10v6m0 0l-3-3m3 3l3-3M3 17V7a2 2 0 012-2h6l2 2h6a2 2 0 012 2v8a2 2 0 01-2 2H5a2 2 0 01-2-2z" />
        </svg>
        Download Resume
      </a>
    </div>

  </div>
</BaseLayout>
