---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const allProjects = await getCollection('projects');
const featured = allProjects
  .filter((p) => p.data.featured)
  .sort((a, b) => a.data.order - b.data.order);
---

<BaseLayout title="Projects — Justin Park">
  <section class="mx-auto max-w-5xl px-6 py-24">
    <h1 class="text-3xl font-bold text-text dark:text-dark-text mb-8">Projects</h1>
    <ul class="space-y-4" role="list">
      {featured.map((p) => (
        <li class="p-6 rounded-2xl border border-border dark:border-dark-border bg-surface dark:bg-dark-surface">
          <h2 class="text-xl font-bold text-text dark:text-dark-text">{p.data.title}</h2>
          <p class="text-text-muted dark:text-dark-text-muted mt-1">{p.data.description}</p>
        </li>
      ))}
    </ul>
  </section>
</BaseLayout>
