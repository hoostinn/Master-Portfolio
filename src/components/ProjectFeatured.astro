---
import Badge from './Badge.astro';
import type { ProjectData } from '../scripts/modal';

interface Props {
  title: string;
  description: string;
  role: string;
  team: string | null;
  stack: string[];
  status: 'shipped' | 'in-progress' | 'archived';
  github: string | null;
  demo: string | null;
  image: string | null;
  projectData: ProjectData;
}

const { title, description, role, team, stack, status, github, demo, image, projectData } =
  Astro.props;
const serialized = JSON.stringify(projectData);
---

<article class="rounded-2xl border border-border dark:border-dark-border bg-surface dark:bg-dark-surface overflow-hidden">
  <div class:list={['flex gap-0', image ? 'flex-col lg:flex-row' : 'flex-col']}>

    <!-- Content -->
    <div class="flex-1 p-8 lg:p-10 flex flex-col">
      <!-- Status + role strip -->
      <div class="flex flex-wrap items-center gap-3 mb-4">
        <Badge variant="status" status={status} label={status} />
        <span class="text-xs font-medium text-text-faint dark:text-dark-text-faint uppercase tracking-wide">
          Featured
        </span>
      </div>

      <h2 class="text-2xl sm:text-3xl font-bold text-text dark:text-dark-text mb-1 leading-tight">
        {title}
      </h2>
      <p class="text-sm font-medium text-primary dark:text-dark-primary mb-0.5">
        {role}
      </p>
      {team && (
        <p class="text-sm text-text-faint dark:text-dark-text-faint mb-4">{team}</p>
      )}

      <p class="text-text-muted dark:text-dark-text-muted leading-relaxed mb-6 mt-3">
        {description}
      </p>

      <!-- Stack badges -->
      <div class="flex flex-wrap gap-2 mb-8">
        {stack.map((s) => <Badge label={s} />)}
      </div>

      <!-- Actions -->
      <div class="flex flex-wrap gap-3 mt-auto">
        <button
          data-modal-trigger
          data-project={serialized}
          class="inline-flex items-center gap-2 px-5 py-2.5 rounded-lg bg-accent hover:bg-accent-hover dark:bg-dark-accent dark:hover:bg-dark-accent-hover text-text font-semibold text-sm transition-colors duration-200 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-accent"
        >
          View Details
        </button>

        {github && (
          <a
            href={github}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-2 px-5 py-2.5 rounded-lg border border-border dark:border-dark-border text-sm font-medium text-text-muted dark:text-dark-text-muted hover:text-text dark:hover:text-dark-text hover:border-primary dark:hover:border-dark-primary transition-colors duration-200"
          >
            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0 1 12 6.844a9.59 9.59 0 0 1 2.504.337c1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.02 10.02 0 0 0 22 12.017C22 6.484 17.522 2 12 2z" />
            </svg>
            GitHub
          </a>
        )}

        {demo && (
          <a
            href={demo}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-2 px-5 py-2.5 rounded-lg border border-border dark:border-dark-border text-sm font-medium text-text-muted dark:text-dark-text-muted hover:text-text dark:hover:text-dark-text hover:border-primary dark:hover:border-dark-primary transition-colors duration-200"
          >
            Live Demo ↗
          </a>
        )}
      </div>
    </div>

    <!-- Screenshot -->
    {image && (
      <div class="lg:w-80 xl:w-96 flex-shrink-0 bg-surface-alt dark:bg-dark-surface-alt flex items-center justify-center overflow-hidden">
        <img
          src={image}
          alt={`${title} screenshot`}
          class="w-full h-full object-cover object-top"
          loading="lazy"
        />
      </div>
    )}

  </div>
</article>
