---
import Badge from './Badge.astro';
import type { ProjectData } from '../scripts/modal';

interface Props {
  title: string;
  description: string;
  stack: string[];
  status: 'shipped' | 'in-progress' | 'archived';
  projectData: ProjectData;
}

const { title, description, stack, status, projectData } = Astro.props;
const topStack = stack.slice(0, 3);
const serialized = JSON.stringify(projectData);
---

<article class="group flex flex-col h-full rounded-2xl border border-border dark:border-dark-border bg-surface dark:bg-dark-surface overflow-hidden hover:border-primary dark:hover:border-dark-primary hover:shadow-md transition-all duration-200">
  <button
    data-modal-trigger
    data-project={serialized}
    class="flex flex-col flex-1 text-left p-6 focus-visible:outline-2 focus-visible:outline-offset-[-2px] focus-visible:outline-accent rounded-2xl"
    aria-label={`View details for ${title}`}
  >
    <!-- Title + status -->
    <div class="flex items-start justify-between gap-3 mb-2">
      <h3 class="text-lg font-bold text-text dark:text-dark-text leading-snug">
        {title}
      </h3>
      <Badge variant="status" status={status} label={status} />
    </div>

    <!-- Description -->
    <p class="text-sm text-text-muted dark:text-dark-text-muted leading-relaxed mb-auto line-clamp-3">
      {description}
    </p>

    <!-- Stack badges -->
    <div class="flex flex-wrap gap-1.5 mt-5">
      {topStack.map((s) => <Badge label={s} />)}
      {stack.length > 3 && (
        <span class="inline-block px-2.5 py-0.5 rounded-full text-xs font-medium text-text-faint dark:text-dark-text-faint">
          +{stack.length - 3} more
        </span>
      )}
    </div>
  </button>
</article>
