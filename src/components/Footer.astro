      &copy; {year} Justin Park
    </p>

    <nav aria-label="Social links">
      <ul class="flex items-center gap-6 list-none m-0 p-0" role="list">
        <li>
          <a
            href="mailto:justin.jpark4@gmail.com"
            class="text-sm text-text-muted dark:text-dark-text-muted hover:text-accent dark:hover:text-dark-accent transition-colors duration-200"
          >
            Email
          </a>
        </li>
        <li>
          <a
            href="https://github.com/OTTER-Capstone-ORG/OTTER"
            target="_blank"
