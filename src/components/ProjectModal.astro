---
// Single modal instance — populated by modal.ts at runtime.
// Render once per page, anywhere inside <body>.
---

<dialog
  id="project-modal"
  aria-labelledby="modal-title"
  aria-modal="true"
  class="w-full max-w-2xl rounded-2xl border border-border dark:border-dark-border bg-surface dark:bg-dark-surface p-0 shadow-2xl backdrop:bg-black/50 backdrop:backdrop-blur-sm"
>
  <div class="p-8 max-h-[85vh] overflow-y-auto">

    <!-- Header row -->
    <div class="flex items-start justify-between gap-4 mb-1">
      <span id="modal-status"></span>
      <button
        id="modal-close-btn"
        aria-label="Close"
        class="flex-shrink-0 p-1.5 rounded-lg text-text-faint dark:text-dark-text-faint hover:text-text dark:hover:text-dark-text hover:bg-surface-alt dark:hover:bg-dark-surface-alt transition-colors duration-200 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-accent"
      >
        <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
        </svg>
      </button>
    </div>

    <!-- Title & meta -->
    <h2
      id="modal-title"
      class="text-2xl font-bold text-text dark:text-dark-text mb-1"
    ></h2>
    <p
      id="modal-role"
      class="text-sm font-medium text-primary dark:text-dark-primary mb-0.5"
    ></p>
    <p
      id="modal-team"
      class="text-sm text-text-faint dark:text-dark-text-faint mb-4 hidden"
    ></p>

    <!-- Description -->
    <p
      id="modal-description"
      class="text-text-muted dark:text-dark-text-muted mb-5 leading-relaxed"
    ></p>

    <!-- Stack badges -->
    <div id="modal-stack" class="flex flex-wrap gap-2 mb-6"></div>

    <!-- Highlights -->
    <ul
      id="modal-highlights"
      class="space-y-2 mb-6 list-none p-0 m-0"
      aria-label="Project highlights"
    ></ul>

    <!-- TPM / product callout -->
    <div
      id="modal-tpm"
      class="hidden rounded-xl bg-surface-alt dark:bg-dark-surface-alt border border-primary/40 dark:border-dark-primary/40 p-4 mb-6"
    >
      <p class="text-xs font-semibold uppercase tracking-widest text-primary dark:text-dark-primary mb-1.5">
        Product &amp; Leadership
      </p>
      <p
        id="modal-tpm-text"
        class="text-sm text-text-muted dark:text-dark-text-muted leading-relaxed"
      ></p>
    </div>

    <!-- Links -->
    <div class="flex gap-3 flex-wrap">
      <a
        id="modal-github"
        href="#"
        target="_blank"
        rel="noopener noreferrer"
        class="hidden inline-flex items-center gap-2 px-4 py-2 rounded-lg border border-border dark:border-dark-border text-sm font-medium text-text-muted dark:text-dark-text-muted hover:text-text dark:hover:text-dark-text hover:border-primary dark:hover:border-dark-primary transition-colors duration-200"
      >
        <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0 1 12 6.844a9.59 9.59 0 0 1 2.504.337c1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.02 10.02 0 0 0 22 12.017C22 6.484 17.522 2 12 2z" />
        </svg>
        GitHub
      </a>
      <a
        id="modal-demo"
        href="#"
        target="_blank"
        rel="noopener noreferrer"
        class="hidden inline-flex items-center gap-2 px-4 py-2 rounded-lg bg-accent hover:bg-accent-hover dark:bg-dark-accent dark:hover:bg-dark-accent-hover text-sm font-semibold text-text transition-colors duration-200"
      >
        Live Demo ↗
      </a>
    </div>

  </div>
</dialog>

<style>
  /* Scroll lock class applied by modal.ts via body.style.overflow */

  #project-modal {
    /* Centre in viewport */
    position: fixed;
    inset: 0;
    margin: auto;
    max-height: min(90vh, 800px);
  }

  /* Open animation */
  #project-modal[open] {
    animation: modal-enter 0.2s ease-out;
  }

  #project-modal::backdrop {
    animation: backdrop-enter 0.2s ease-out;
  }

  @keyframes modal-enter {
    from { opacity: 0; transform: translateY(12px) scale(0.97); }
    to   { opacity: 1; transform: translateY(0)   scale(1);    }
  }

  @keyframes backdrop-enter {
    from { opacity: 0; }
    to   { opacity: 1; }
  }

  @media (prefers-reduced-motion: reduce) {
    #project-modal[open],
    #project-modal::backdrop { animation: none; }
  }
</style>

<script>
  import '../scripts/modal';
</script>
